# Login Microsoft (Entra ID / Azure AD) — Cattalini
# Copie para .env.local (local) ou configure no Vercel → Settings → Environment Variables.
# Deixe VAZIO para o app abrir SEM login (comportamento atual).

# Directory (tenant) ID do Azure AD da Cattalini
VITE_AZURE_TENANT_ID=

# Application (client) ID do App Registration (tipo: SPA)
VITE_AZURE_CLIENT_ID=

# (opcional) Restringe por domínio de e-mail. Aceita lista separada por vírgula.
# Ex.: cattaliniterminais.com.br,cattalini.com.br
VITE_AZURE_ALLOWED_DOMAIN=
